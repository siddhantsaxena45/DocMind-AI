{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Backend (FastAPI)",
            "type": "shell",
            "command": "${workspaceFolder}/backend/venv/Scripts/python",
            "args": [
                "-m",
                "pip",
                "install",
                "-r",
                "requirements.txt",
                "&&",
                "${workspaceFolder}/backend/venv/Scripts/python",
                "-m",
                "uvicorn",
                "main:app",
                "--reload"
            ],
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "docmind-services"
            },
            "problemMatcher": []
        },
        {
            "label": "Frontend (Vite)",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "dev"
            ],
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "docmind-services"
            },
            "problemMatcher": []
        },
        {
            "label": "Start DocMind",
            "dependsOn": [
                "Backend (FastAPI)",
                "Frontend (Vite)"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
